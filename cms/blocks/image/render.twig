{% set width = data.width|default('full') %}
{% set maxw = width == 'narrow' ? '480px' : (width == 'wide' ? '960px' : '100%') %}
{% if data.src %}
<figure style="margin: 1rem auto; max-width: {{ maxw }}">
  <img src="{{ data.src }}" alt="{{ data.alt|default('') }}" style="display:block;width:100%;height:auto">
  {% if data.caption %}<figcaption style="text-align:center;font-size:.875rem;color:#666;margin-top:.5rem">{{ data.caption }}</figcaption>{% endif %}
</figure>
{% else %}
<!-- image block: no src set -->
{% endif %}
