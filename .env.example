# Admin credentials.
#
# On first request to /admin/, the plaintext ADMIN_PASS is hashed with
# bcrypt and the file is rewritten to ADMIN_PASS_HASH=… (the plaintext
# line is removed). Subsequent requests see only the hash.
#
# If you'd rather skip the auto-hash and start hashed from day one, set
# ADMIN_PASS_HASH directly and leave ADMIN_PASS blank:
#
#   php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
#
# Either way: change the default before going public.
ADMIN_USER=admin
ADMIN_PASS=admin
ADMIN_PASS_HASH=

# `dev` (default) auto-compiles a theme's SCSS on every public-site request
# whenever a source file is newer than its CSS. Set to anything else (e.g.
# `prod`) on a deployed host to skip the freshness check entirely.
APP_ENV=dev

# Show admin API exception messages to the client. Defaults off — exceptions
# are written to the PHP error log and the client sees a generic message.
APP_DEBUG=0

# Idle-timeout for admin sessions (seconds). 0 disables the idle check.
SESSION_IDLE_SECONDS=7200
